# Local PostgreSQL database name used by docker-compose.
POSTGRES_DB=moneyleakdb

# Local PostgreSQL username used by docker-compose.
POSTGRES_USER=moneyleak

# Local PostgreSQL password. Change this before any shared deployment.
POSTGRES_PASSWORD=change-this-local-postgres-password

# Backend database URL. Render/Neon should set this to the cloud PostgreSQL connection string.
DATABASE_URL=postgresql://moneyleak:password@localhost:5432/moneyleakdb

# JWT signing secret. Use a strong random value of at least 32 characters in production.
SECRET_KEY=change-this-minimum-32-character-local-secret-key

# JWT algorithm. Keep HS256 unless you intentionally migrate token signing.
ALGORITHM=HS256

# Access token lifetime in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Comma-separated frontend origins allowed by CORS. In production, use only your Vercel URL.
ALLOWED_ORIGINS=http://localhost:5173

# Maximum CSV/Excel upload size in MB.
MAX_UPLOAD_SIZE_MB=10

# Runtime mode. Use production on Render; production rejects wildcard and localhost CORS origins.
ENVIRONMENT=development

# Optional Anthropic API key for AI-enhanced merchant discovery and recommendations.
ANTHROPIC_API_KEY=

# Reserved optional OpenAI API key for deployments that add an OpenAI provider.
OPENAI_API_KEY=

# Maximum duration for external AI requests; allowed range is 0-30 seconds.
AI_REQUEST_TIMEOUT_SECONDS=10

# Cookie security flag for future cookie-based auth. Current app uses Bearer JWT headers.
SECURE_COOKIES=false

# Lightweight in-memory limits for auth and statement upload endpoints.
RATE_LIMIT_AUTH_PER_MINUTE=120
RATE_LIMIT_UPLOADS_PER_MINUTE=30

# Frontend API base URL. Vercel should set this to your Render backend URL.
VITE_API_URL=http://localhost:8000
