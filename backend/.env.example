# PostgreSQL connection string. Use Neon/Supabase/Render PostgreSQL in production.
DATABASE_URL=postgresql://moneyleak:password@localhost:5432/moneyleakdb

# JWT signing secret. Must be a random string of at least 32 characters in production.
SECRET_KEY=your-secret-key-minimum-32-chars

# JWT algorithm used by python-jose.
ALGORITHM=HS256

# JWT access-token expiry in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Allowed browser origins. Production must use your exact Vercel domain, not localhost or *.
ALLOWED_ORIGINS=http://localhost:5173

# Maximum upload size in MB for CSV/XLS/XLSX bank statements.
MAX_UPLOAD_SIZE_MB=10

# Runtime environment: development or production.
ENVIRONMENT=development

# Optional Anthropic API key. If empty, AI endpoints return deterministic rule-based fallbacks.
ANTHROPIC_API_KEY=

# Reserved optional OpenAI API key for deployments that add an OpenAI provider.
OPENAI_API_KEY=

# Maximum duration for external AI requests; allowed range is 0-30 seconds.
AI_REQUEST_TIMEOUT_SECONDS=10

# Cookie security flag for future cookie usage. Current auth uses Authorization: Bearer tokens.
SECURE_COOKIES=false

# Lightweight in-memory limits for auth and statement upload endpoints.
RATE_LIMIT_AUTH_PER_MINUTE=120
RATE_LIMIT_UPLOADS_PER_MINUTE=30
